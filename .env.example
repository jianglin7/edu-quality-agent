# 复制为 .env 后填写真实值（.env 已在 .gitignore 中，勿提交仓库）
# cp .env.example .env

# ---------- LLM 网关（P0-01 / P0-03）----------
LLM_API_BASE=https://your-llm-gateway.example.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SEC=60

# ---------- 统一认证（P0-02）----------
JWT_SECRET=replace-me
JWT_ALGORITHM=HS256
# 测试用 Token 由业务系统签发，勿将生产 Token 写入本文件

# ---------- 只读数仓（P0-07 / P0-08）----------
DB_READONLY_URL=mysql+pymysql://readonly:password@host:3306/edu_ai_dw?charset=utf8mb4
DB_QUERY_TIMEOUT_SEC=10

# ---------- 埋点库（P0-06）----------
LIFECYCLE_DB_URL=mysql+pymysql://app:password@host:3306/app_db?charset=utf8mb4

# ---------- LangGraph Checkpointer（可选，生产建议 Postgres）----------
# CHECKPOINTER_DB_URL=postgresql://user:pass@host:5432/langgraph

# ---------- 应用 ----------
APP_ENV=dev
LOG_LEVEL=INFO
BASELINE_DATE=2026-05-20
